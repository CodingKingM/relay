# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Database
DB_URL=jdbc:mariadb://localhost:3306/relay?createDatabaseIfNotExist=true
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Set to true when running behind HTTPS (production)
COOKIE_SECURE=false

# Frontend
VITE_API_URL=/api
